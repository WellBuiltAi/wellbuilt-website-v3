---
const qualifications = [
  "You run paid ads for local service businesses",
  "Your agency does $30K+/mo in revenue",
  "Client churn is eating your growth",
  "You want to add revenue",
  "Your margins are already too thin to hire",
];
---

<section id="booking" class="py-32 md:py-40 px-6 md:px-12 w-full flex justify-center bg-transparent relative overflow-hidden">
  <!-- Ambient glows -->
  <div class="absolute top-[20%] right-[-10%] w-[70vw] h-[70vw] max-w-[1000px] max-h-[1000px] opacity-[0.08] mix-blend-screen pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(178, 133, 27, 0.35) 0%, rgba(178, 133, 27, 0) 55%)"></div>
  <div class="absolute top-1/2 left-[-10%] -translate-y-1/2 w-[500px] h-[500px] opacity-[0.06] mix-blend-screen pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(178, 133, 27, 0.3) 0%, rgba(178, 133, 27, 0) 50%)"></div>

  <div class="max-w-[1400px] w-full mx-auto flex flex-col items-center relative z-10">

    <!-- Header -->
    <div class="text-center mb-10 md:mb-20">
      <div class="inline-flex items-center gap-2 md:gap-3 border border-accent/30 bg-accent/[0.06] rounded-full px-4 md:px-5 py-1.5 md:py-2 mb-6 md:mb-8">
        <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_rgba(239,68,68,0.6)]"></div>
        <span class="font-mono text-[10px] md:text-[11px] text-accent tracking-[0.2em] md:tracking-[0.25em] uppercase font-bold">Only 2 Slots Left</span>
      </div>
      <h2 class="text-4xl md:text-7xl lg:text-8xl font-sans font-bold uppercase tracking-tighter leading-[0.9] drop-shadow-[0_20px_20px_rgba(0,0,0,0.8)]">
        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#ffffff] via-[#d4d4d4] to-[#737373] inline" style="filter: drop-shadow(0px 2px 2px rgba(255,255,255,0.3))">DEPLOY THE </span>
        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#fcd34d] via-[#b48618] to-[#5c4004] inline font-drama italic font-normal tracking-tight" style="filter: drop-shadow(0px 2px 2px rgba(228,172,38,0.4))">SYSTEM</span>
      </h2>
    </div>

    <!-- Qualifications — no card, just clean list -->
    <div class="flex flex-col items-start gap-3 md:gap-5 w-fit mb-12 md:mb-16 mx-auto">
      {qualifications.map((item) => (
        <div class="flex items-center gap-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0 md:w-[18px] md:h-[18px]"><path d="M20 6 9 17l-5-5"/></svg>
          <span class="text-white/80 font-sans text-sm md:text-xl leading-snug">{item}</span>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <a
      href="/book"
      class="relative group text-foreground mx-auto text-center rounded-full font-bold tracking-widest uppercase transition-all overflow-hidden bg-[#B2851B] hover:bg-[#c29624] text-[#050505] border border-[#B2851B]/50 shadow-[0_0_20px_rgba(178,133,27,0.3)] hover:shadow-[0_0_40px_rgba(178,133,27,0.6)] px-6 md:px-12 py-3 md:py-5 text-xs md:text-base w-auto inline-flex items-center justify-center gap-2 md:gap-3 no-underline"
    >
      <span class="absolute h-[2px] opacity-0 group-hover:opacity-100 transition-all duration-500 ease-in-out inset-x-0 top-0 bg-gradient-to-r w-3/4 mx-auto from-transparent via-white to-transparent"></span>
      <span class="relative z-10 flex items-center justify-center gap-3">
        Book Your Discovery Call
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-80"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </span>
      <span class="absolute group-hover:opacity-50 transition-all duration-500 ease-in-out inset-x-0 h-[2px] bottom-0 bg-gradient-to-r w-3/4 mx-auto from-transparent via-[#FFD700] to-transparent"></span>
    </a>
  </div>
</section>
