---
const year = new Date().getFullYear();
---

<footer class="w-full bg-[#050505] pt-12 pb-8 px-6 md:px-12 relative overflow-hidden flex flex-col items-center justify-center">
  <!-- Top Border Horizontal Linear Glow -->
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-accent/80 to-transparent shadow-[0_0_20px_rgba(178,133,27,0.8)]"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-[30px] bg-gradient-to-b from-accent/20 to-transparent blur-[15px] pointer-events-none"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[30%] h-[15px] bg-gradient-to-b from-accent/40 to-transparent blur-[8px] pointer-events-none"></div>

  <a href="/" class="inline-block mb-4 relative z-10 mt-6 md:mt-0">
    <img src="/logo.png" alt="WellBuilt AI Logo" width="90" height="30" class="h-[25px] md:h-[30px] w-auto object-contain opacity-50 hover:opacity-100 transition-opacity" />
  </a>

  <div class="font-mono text-[10px] text-white/30 uppercase tracking-[0.2em] text-center relative z-10">
    &copy; {year} WellBuilt AI.
  </div>
</footer>
