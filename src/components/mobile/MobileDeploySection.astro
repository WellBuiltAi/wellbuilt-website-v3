---
const qualifications = [
  "You run paid ads for local service businesses",
  "Your agency does $30K+/mo in revenue",
  "You're losing leads to slow follow-up",
  "You want to add revenue — not rebuild your stack",
];
---

<section id="mobile-booking" class="relative w-full py-20 px-5 bg-transparent overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-[20%] right-[-15%] w-[80vw] h-[80vw] opacity-[0.06] mix-blend-screen pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(178, 133, 27, 0.3) 0%, rgba(178, 133, 27, 0) 55%)"></div>

  <div class="flex flex-col items-center relative z-10">

    <!-- Header -->
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2.5 border border-accent/30 bg-accent/[0.06] rounded-full px-4 py-1.5 mb-6">
        <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_rgba(239,68,68,0.6)]"></div>
        <span class="font-mono text-[10px] text-accent tracking-[0.2em] uppercase font-bold">Only 2 Slots Left</span>
      </div>
      <h2 class="text-3xl font-sans font-bold uppercase tracking-tighter leading-[0.95]">
        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#ffffff] via-[#d4d4d4] to-[#737373]">DEPLOY THE </span>
        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#fcd34d] via-[#b48618] to-[#5c4004]">SYSTEM</span>
      </h2>
    </div>

    <!-- Qualifications -->
    <div class="flex flex-col items-start gap-4 w-full mb-10">
      {qualifications.map((item) => (
        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
          <span class="text-white/80 font-sans text-base leading-snug">{item}</span>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <button
      onclick="window.openBooking?.()"
      class="w-full rounded-full font-bold tracking-widest uppercase bg-[#B2851B] hover:bg-[#c29624] text-[#050505] border border-[#B2851B]/50 shadow-[0_0_20px_rgba(178,133,27,0.3)] px-8 py-4 text-sm inline-flex items-center justify-center gap-2 cursor-pointer"
    >
      Book Your Discovery Call
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-80"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </button>
  </div>
</section>
