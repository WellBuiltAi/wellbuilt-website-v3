---
const year = new Date().getFullYear();
---

<footer class="w-full bg-[#050505] pt-10 pb-8 px-5 relative overflow-hidden flex flex-col items-center justify-center">
  <!-- Top glow line -->
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-accent/80 to-transparent shadow-[0_0_15px_rgba(178,133,27,0.6)]"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-[20px] bg-gradient-to-b from-accent/15 to-transparent blur-[12px] pointer-events-none"></div>

  <a href="/" class="inline-block mb-3 mt-4 relative z-10">
    <img src="/logo.png" alt="WellBuilt AI Logo" class="h-[22px] w-auto object-contain opacity-50" />
  </a>

  <div class="font-mono text-[9px] text-white/25 uppercase tracking-[0.2em] text-center relative z-10">
    &copy; {year} WellBuilt AI.
  </div>
</footer>
