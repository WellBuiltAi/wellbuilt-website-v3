---
const steps = [
  { num: "01", title: "THE REVENUE UPSELL", desc: "Command a new $3K–$10K setup fee plus ongoing performance retainer—pure-profit revenue without hiring.", icon: "activity" },
  { num: "02", title: "CRM & CAMPAIGN SYNC", desc: "Hooks into your client's CRM and ad campaigns, instantly routing all new leads to the AI.", icon: "database" },
  { num: "03", title: "DATABASE REACTIVATION", desc: "Reactivate dead leads and turn them into booked jobs—generating revenue from day one.", icon: "refresh" },
  { num: "04", title: "INSTANT ENGAGEMENT", desc: "The second a lead clicks submit, Voice and SMS AI fire simultaneously—when intent is at its peak.", icon: "zap" },
  { num: "05", title: "AUTOMATED CLOSING", desc: "Drives leads straight into your client's schedule and captures deposit payments. Zero human intervention.", icon: "calendar" },
  { num: "06", title: "UNBREAKABLE RETENTION", desc: "Better results from the same ad spend. Clients pay more and stay longer. Completely irreplaceable.", icon: "shield" },
];

const iconPaths: Record<string, string> = {
  activity: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  database: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>',
  refresh: '<path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/>',
  zap: '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',
  calendar: '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
};
---

<section class="relative w-full py-20 px-5 bg-transparent border-b border-white/10 overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-[10%] right-[-25%] w-[80vw] h-[80vw] opacity-[0.1] mix-blend-screen pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(178, 133, 27, 0.3) 0%, rgba(178, 133, 27, 0) 60%)"></div>

  <div class="flex flex-col items-center">

    <!-- Header -->
    <div class="text-center mb-12">
      <span class="font-mono text-[10px] text-accent tracking-[0.3em] uppercase mb-5 block font-medium">How It Works</span>
      <h2 class="text-3xl font-sans font-bold uppercase tracking-tighter leading-[0.95]">
        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#ffffff] via-[#d4d4d4] to-[#737373]">THE SYSTEM </span>
        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#fcd34d] via-[#b48618] to-[#5c4004]">MECHANICS</span>
      </h2>
    </div>

    <!-- Steps -->
    <div class="flex flex-col items-center w-full gap-4 relative">
      {steps.map((step, i) => (
        <div class="w-full flex flex-col items-center">
          <!-- Step Card -->
          <div class="w-full bg-white/[0.03] border border-white/5 rounded-2xl p-5 relative">
            <!-- Step badge + icon row -->
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-full bg-[#050505] border border-accent/20 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent/80" set:html={iconPaths[step.icon]} />
              </div>
              <div class="font-mono text-[10px] text-accent/70 tracking-widest">STEP {step.num}</div>
            </div>

            <h3 class="font-sans text-base font-bold text-accent uppercase tracking-wider mb-2 drop-shadow-[0_0_8px_rgba(178,133,27,0.3)]">{step.title}</h3>
            <p class="text-white/50 font-sans text-sm leading-relaxed">{step.desc}</p>
          </div>

          <!-- Connecting line -->
          {i !== steps.length - 1 && (
            <div class="w-[2px] h-4 bg-accent/25"></div>
          )}
        </div>
      ))}
    </div>

  </div>
</section>
