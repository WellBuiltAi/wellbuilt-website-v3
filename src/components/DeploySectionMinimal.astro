---
---

<section id="booking" class="py-40 md:py-56 px-6 md:px-12 w-full flex justify-center bg-transparent relative overflow-hidden">
  <!-- Subtle ambient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[70vw] h-[50vw] max-w-[900px] max-h-[600px] opacity-[0.06] mix-blend-screen pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(178, 133, 27, 0.35) 0%, rgba(178, 133, 27, 0) 55%)"></div>

  <div class="max-w-[850px] w-full mx-auto flex flex-col items-center relative z-10">

    <!-- Header — clean, centered -->
    <div class="text-center mb-6">
      <h2 class="text-5xl md:text-7xl lg:text-8xl font-sans font-bold uppercase tracking-tighter leading-[0.9] drop-shadow-[0_20px_20px_rgba(0,0,0,0.8)]">
        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#ffffff] via-[#d4d4d4] to-[#737373] block pb-2" style="filter: drop-shadow(0px 2px 2px rgba(255,255,255,0.3))">BOOK YOUR</span>
        <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#fcd34d] via-[#b48618] to-[#5c4004] block mt-1" style="filter: drop-shadow(0px 2px 2px rgba(228,172,38,0.4))">STRATEGY CALL</span>
      </h2>
    </div>

    <!-- One-liner qualifier -->
    <p class="text-white/30 font-sans text-sm md:text-base text-center max-w-md mb-16">
      We partner with agencies doing $30K+/mo who are ready to add a revenue layer — not rebuild from scratch.
    </p>

    <!-- Thin accent divider -->
    <div class="w-24 h-[1px] bg-gradient-to-r from-transparent via-accent/30 to-transparent mb-16"></div>

    <!-- Cal.com Calendar — Centered -->
    <div class="w-full relative">
      <div class="relative w-full h-[520px] md:h-[650px] rounded-2xl overflow-hidden shadow-[0_0_40px_rgba(0,0,0,0.4)] border border-white/[0.04] bg-[#050505]">
        <iframe
          src="https://cal.com/wellbuiltai/discovery?theme=dark&hideEventTypeDetails=true"
          width="100%"
          height="100%"
          frameborder="0"
          scrolling="no"
          title="Strategy Session"
          class="absolute top-0 left-0 w-full h-full"
          style="overflow: hidden; color-scheme: dark;"
        ></iframe>
      </div>
    </div>

    <!-- Thin accent divider -->
    <div class="w-24 h-[1px] bg-gradient-to-r from-transparent via-accent/30 to-transparent mt-16"></div>

  </div>
</section>
