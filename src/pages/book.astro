---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Book a Discovery Call — WellBuilt AI</title>
  <meta name="description" content="Schedule your free discovery call with WellBuilt AI. See how CloseStack can add $5k–$15k MRR to your agency." />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="apple-touch-icon" href="/logo.png" />
</head>
<body class="bg-[#000000] text-white" style="margin:0;padding:0;overflow:hidden;">
  <div style="position:fixed;top:0px;left:0px;right:0px;bottom:0px;">
    <div data-fillout-id="76huBbS4evus" data-fillout-embed-type="fullscreen" style="width:100%;height:100%;" data-fillout-inherit-parameters data-fillout-domain="discovery.wellbuiltai.com"></div>
    <script src="https://server.fillout.com/embed/v1/"></script>
  </div>
  <Analytics />
  <SpeedInsights />
</body>
</html>
