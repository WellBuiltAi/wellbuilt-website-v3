---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackgroundTexture from '../components/BackgroundTexture.astro';
import DeploySectionCinematic from '../components/DeploySectionCinematic.astro';
import DeploySectionMinimal from '../components/DeploySectionMinimal.astro';
import DeploySectionPolished from '../components/DeploySectionPolished.astro';
---

<BaseLayout title="Booking Section Previews — WellBuilt AI" description="Preview booking section variants for WellBuilt AI.">
  <div class="relative w-full min-h-screen bg-[#050505] text-white font-mono">
    <BackgroundTexture />

    <div class="relative z-10 w-full">

      <!-- Page Header -->
      <div class="py-16 px-6 text-center border-b border-white/10">
        <h1 class="text-3xl md:text-4xl font-sans font-bold uppercase tracking-tighter text-white mb-2">Booking Section Previews</h1>
        <p class="text-white/30 font-mono text-sm">Scroll to compare all 3 variants</p>
      </div>

      <!-- VARIANT A: Cinematic Full-Width -->
      <div class="border-b border-white/10">
        <div class="py-8 px-6 text-center">
          <span class="font-mono text-[11px] text-accent tracking-[0.35em] uppercase font-medium">Variant A</span>
          <h2 class="text-xl font-sans font-bold uppercase tracking-wider text-white/60 mt-2">Cinematic Full-Width</h2>
        </div>
        <DeploySectionCinematic />
      </div>

      <!-- VARIANT B: Minimal Premium -->
      <div class="border-b border-white/10">
        <div class="py-8 px-6 text-center">
          <span class="font-mono text-[11px] text-accent tracking-[0.35em] uppercase font-medium">Variant B</span>
          <h2 class="text-xl font-sans font-bold uppercase tracking-wider text-white/60 mt-2">Minimal Premium</h2>
        </div>
        <DeploySectionMinimal />
      </div>

      <!-- VARIANT C: Polished 2-Column -->
      <div class="border-b border-white/10">
        <div class="py-8 px-6 text-center">
          <span class="font-mono text-[11px] text-accent tracking-[0.35em] uppercase font-medium">Variant C</span>
          <h2 class="text-xl font-sans font-bold uppercase tracking-wider text-white/60 mt-2">Polished 2-Column</h2>
        </div>
        <DeploySectionPolished />
      </div>

    </div>
  </div>
</BaseLayout>
