---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "WellBuilt AI — Multiply Your Agency's Revenue",
  description = "WellBuilt AI — CloseStack™ system for SMMA agencies serving local service businesses. AI-powered lead engagement, database reactivation, and automated closing that adds $5k–$15k MRR to your agency without ad spend."
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://wellbuilt.ai');
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL.href} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://wellbuilt.ai/logo.png" />
  <meta property="og:site_name" content="WellBuilt AI" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://wellbuilt.ai/logo.png" />

  <!-- Fonts: render-blocking with display=optional to prevent CLS -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Space+Grotesk:wght@400..700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=optional"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Space+Grotesk:wght@400..700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=optional"
  />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "WellBuilt AI",
    "url": "https://wellbuilt.ai",
    "logo": "https://wellbuilt.ai/logo.png",
    "description": description,
    "sameAs": []
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "WellBuilt AI",
    "url": "https://wellbuilt.ai"
  })} />
</head>

<body class="bg-[#000000] text-white">
  <!-- Noise overlay — 100% viewport, GPU-composited via will-change -->
  <div id="noise-layer" aria-hidden="true"
    style="position: fixed; inset: 0; pointer-events: none; z-index: 9999; opacity: 0.04; background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27n%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.75%27 numOctaves=%271%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23n)%27/%3E%3C/svg%3E'); background-size: 256px 256px; contain: strict; will-change: transform;">
  </div>

  <slot />

  <!-- Fillout Popup Modal — centered on screen -->
  <div id="booking-overlay" style="display:none; position:fixed; inset:0; z-index:99999; background:rgba(0,0,0,0.75); backdrop-filter:blur(4px);">
    <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:90vw; max-width:600px; height:85vh; max-height:800px; border-radius:16px; overflow:hidden; background:#fff;">
      <button onclick="closeBooking()" style="position:absolute; top:8px; right:8px; z-index:10; background:rgba(0,0,0,0.08); border:none; border-radius:50%; width:32px; height:32px; cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; color:#333;">&#10005;</button>
      <iframe id="booking-frame" src="" style="width:100%; height:100%; border:none;" loading="lazy"></iframe>
    </div>
  </div>
  <script is:inline>
    window.openBooking = function() {
      var overlay = document.getElementById('booking-overlay');
      var frame = document.getElementById('booking-frame');
      if (!frame.src || frame.src === window.location.href || frame.src === '') {
        frame.src = 'https://discovery.wellbuiltai.com/76huBbS4evus';
      }
      overlay.style.display = 'block';
      document.body.style.overflow = 'hidden';
    };
    window.closeBooking = function() {
      document.getElementById('booking-overlay').style.display = 'none';
      document.body.style.overflow = '';
    };
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeBooking();
    });
    document.getElementById('booking-overlay').addEventListener('click', function(e) {
      if (e.target === this) closeBooking();
    });
  </script>

  <Analytics />
  <SpeedInsights />
</body>
</html>
